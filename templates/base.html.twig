<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}WattUp{% endblock %}</title>

    {# Bootstrap #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    {# Bootstrap Icons #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background-color: #181a1f;
            color: #e4e6eb;
        }

        /* NAVBAR */
        .navbar {
            background-color: #20232a !important;
            border-bottom: 1px solid #2d3139;
        }

        .navbar-brand {
            font-weight: 700;
            color: #5ea8ff !important;
        }

        .nav-link {
            color: #d1d5db !important;
            transition: 0.2s;
            border-radius: 8px;
            padding: 8px 12px !important;
        }

        .nav-link:hover {
            background-color: #2d3139;
            color: #5ea8ff !important;
        }

        /* PAGE */
        .container-page {
            padding: 30px;
        }

        h1, h2, h3 {
            color: #f3f4f6;
        }

        /* TABLES */
        table {
            background-color: #20232a !important;
            color: #e4e6eb !important;
            border-radius: 10px;
            overflow: hidden;
        }

        table thead {
            background-color: #2b3038;
        }

        table th {
            color: #ffffff;
            border: none !important;
            padding: 14px !important;
        }

        table td {
            border-color: #2d3139 !important;
            padding: 12px !important;
        }

        table tr:hover {
            background-color: #2a2f37;
        }

        /* CARDS */
        .card {
            background-color: #20232a;
            border: 1px solid #2d3139;
            color: #e4e6eb;
        }

        /* BUTTONS */
        .btn-primary {
            background-color: #5ea8ff;
            border: none;
            border-radius: 8px;
        }

        .btn-primary:hover {
            background-color: #3f8efc;
        }

        /* LINKS */
        a {
            color: #5ea8ff;
            text-decoration: none;
        }

        a:hover {
            color: #8cc0ff;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
    <div class="container-fluid">

        <a class="navbar-brand" href="{{ path('app_home') }}">
            <i class="bi bi-tools"></i> WattUp
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">

            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_intervention_index') }}">
                        <i class="bi bi-clipboard-check"></i> Intervention
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_client_index') }}">
                        <i class="bi bi-people"></i> Client
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_stock_index') }}">
                        <i class="bi bi-box-seam"></i> Stock
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_materiel_index') }}">
                        <i class="bi bi-pc-display"></i> Matériel
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_technicien_index') }}">
                        <i class="bi bi-person-gear"></i> Technicien
                    </a>
                </li>

                {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="{{ path('app_logout') }}">
                            <i class="bi bi-box-arrow-right"></i> Déconnexion
                        </a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-link text-success" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right"></i> Connexion
                        </a>
                    </li>
                {% endif %}

            </ul>

        </div>
    </div>
</nav>

<div class="container-page">
    {% block body %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}{% endblock %}

</body>
</html>
