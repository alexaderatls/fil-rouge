{% extends 'base.html.twig' %}

{% block title %}Index des Interventions{% endblock %}

{% block body %}
    <h1>Index des Interventions</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Type intervention</th>
                <th>Statut</th>
                <th>Date intervention</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for intervention in interventions %}
            <tr>
                <td>{{ intervention.id }}</td>
                <td>{{ intervention.typeintervention }}</td>
                <td>{{ intervention.statut }}</td>
                <td>{{ intervention.dateintervention ? intervention.dateintervention|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                        <a class="btn btn-sm btn-outline-info"
       href="{{ path('app_intervention_show', {'id': intervention.id}) }}">
        <i class="bi bi-eye"></i>
    </a>

    <a class="btn btn-sm btn-outline-warning"
       href="{{ path('app_intervention_edit', {'id': intervention.id}) }}">
        <i class="bi bi-pencil"></i>
    </a>

</div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a class="btn btn-primary mb-3" href="{{ path('app_intervention_new') }}">
    <i class="bi bi-plus-circle"></i> Créer une nouvelle intervention
</a>
{% endblock %}
