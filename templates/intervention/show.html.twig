{% extends 'base.html.twig' %}

{% block title %}Intervention{% endblock %}

{% block body %}
    <h1>Intervention</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ intervention.id }}</td>
            </tr>
            <tr>
                <th>Type intervention</th>
                <td>{{ intervention.typeintervention }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ intervention.statut }}</td>
            </tr>
            <tr>
                <th>Date intervention</th>
                <td>{{ intervention.dateintervention ? intervention.dateintervention|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-primary" href="{{ path('app_intervention_edit', {'id': intervention.id}) }}">
    <i class="bi bi-pencil"></i> Modifier
</a>

    {{ include('intervention/_delete_form.html.twig') }}

    <a class="btn btn-secondary mb-3" href="{{ path('app_intervention_index') }}">
    <i class="bi bi-arrow-left"></i> Retour à la liste
</a>
{% endblock %}
