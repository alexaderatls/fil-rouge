{% extends 'base.html.twig' %}

{% block title %}Index des Matériaux{% endblock %}

{% block body %}
    <h1>Index des Matériaux</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Type</th>
                <th>Quantité utilisé</th>
                <th>Intervention</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for materiel in materiels %}
            <tr>
                <td>{{ materiel.id }}</td>
                <td>{{ materiel.type }}</td>
                <td>{{ materiel.quantiteUtilise }}</td>
                <td>{{ materiel.intervention.id }}</td>
                <td>
                        <a class="btn btn-sm btn-outline-info"
       href="{{ path('app_materiel_show', {'id': materiel.id}) }}">
        <i class="bi bi-eye"></i>
    </a>

    <a class="btn btn-sm btn-outline-warning"
       href="{{ path('app_materiel_edit', {'id': materiel.id}) }}">
        <i class="bi bi-pencil"></i>
    </a>

</div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a class="btn btn-primary mb-3" href="{{ path('app_materiel_new') }}">
    <i class="bi bi-plus-circle"></i> Ajouter un nouveau matériel
</a>
{% endblock %}
