{% extends 'base.html.twig' %}

{% block title %}Stock{% endblock %}

{% block body %}
    <h1>Stock</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ stock.id }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ stock.type }}</td>
            </tr>
            <tr>
                <th>Quantité</th>
                <td>{{ stock.quantite }}</td>
            </tr>
            <tr>
                <th>Référence</th>
                <td>{{ stock.reference }}</td>
            </tr>
            <tr>
                <th>Prix unitaire</th>
                <td>{{ stock.prixUnitaire }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-primary" href="{{ path('app_stock_edit', {'id': stock.id}) }}">
    <i class="bi bi-pencil"></i> Modifier
</a>

    {{ include('stock/_delete_form.html.twig') }}

    <a class="btn btn-secondary mb-3" href="{{ path('app_stock_index') }}">
    <i class="bi bi-arrow-left"></i> Retour à la liste
</a>
{% endblock %}
