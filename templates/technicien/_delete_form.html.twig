<form method="post" action="{{ path('app_technicien_delete', {'id': technicien.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ technicien.id) }}">
    <button class="btn btn-danger"
        onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet élément?');">

    <i class="bi bi-trash"></i> Supprimer
</button>
</form>
