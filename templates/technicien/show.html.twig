{% extends 'base.html.twig' %}

{% block title %}Technicien{% endblock %}

{% block body %}
    <h1>Technicien</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ technicien.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ technicien.nom }}</td>
            </tr>
            <tr>
                <th>Prénom</th>
                <td>{{ technicien.prenom }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ technicien.email }}</td>
            </tr>
            <tr>
                <th>Matricule</th>
                <td>{{ technicien.matricule }}</td>
            </tr>
        </tbody>
    </table>

    <a class="btn btn-primary" href="{{ path('app_technicien_edit', {'id': technicien.id}) }}">
    <i class="bi bi-pencil"></i> Modifier
</a>

    {{ include('technicien/_delete_form.html.twig') }}

    <a class="btn btn-secondary mb-3" href="{{ path('app_technicien_index') }}">
    <i class="bi bi-arrow-left"></i> Retour à la liste
</a>
{% endblock %}
